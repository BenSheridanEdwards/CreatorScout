# =============================================================================
# Scout Instagram Automation - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: SmartProxy (Residential Proxies)
# -----------------------------------------------------------------------------
# Get from: https://smartproxy.com/dashboard
SMARTPROXY_USERNAME=sp1234567
SMARTPROXY_PASSWORD=your_smartproxy_password_here
SMARTPROXY_HOST=gate.smartproxy.com
SMARTPROXY_PORT=7000

# -----------------------------------------------------------------------------
# REQUIRED: GoLogin (Browser Fingerprinting)
# -----------------------------------------------------------------------------
# Get from: https://gologin.com - Create a profile and get token from API settings
# Note: Individual profile tokens go in profiles.config.json
GOLOGIN_API_TOKEN=your-gologin-profile-token-here

# -----------------------------------------------------------------------------
# REQUIRED: Instagram Credentials
# -----------------------------------------------------------------------------
# Your Instagram account credentials (preferably a dedicated account)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# -----------------------------------------------------------------------------
# REQUIRED: OpenRouter (Vision AI for bio/screenshot analysis)
# -----------------------------------------------------------------------------
# Get from: https://openrouter.ai - Add credits and create API key
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# -----------------------------------------------------------------------------
# REQUIRED: Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Railway: Auto-provided when you add Postgres plugin
# Supabase: Get from Project Settings → Database → Connection String
# Local: postgresql://postgres:postgres@localhost:5432/scout
DATABASE_URL=postgresql://user:password@localhost:5432/scout

# -----------------------------------------------------------------------------
# OPTIONAL: Development & Testing Flags
# -----------------------------------------------------------------------------
# Use local Puppeteer instead of GoLogin (for testing)
LOCAL_BROWSER=false

# Enable verbose debug logging (VERY detailed logs)
DEBUG_LOGS=false

# Fast mode (reduced delays, skip some checks - testing only)
FAST_MODE=false

# Skip vision API calls (cheaper, less accurate)
SKIP_VISION=false

# -----------------------------------------------------------------------------
# OPTIONAL: GoLogin Advanced Settings
# -----------------------------------------------------------------------------
# Use local Orbita browser instead of remote GoLogin cloud
GOLOGIN_USE_LOCAL=false

# Your VPS IP (for GoLogin to connect back)
GOLOGIN_VPS_IP=

# -----------------------------------------------------------------------------
# OPTIONAL: Delay & Timeout Scaling
# -----------------------------------------------------------------------------
# Multiply all delays by this factor (0.5 = faster, 2.0 = slower)
DELAY_SCALE=1.0

# Multiply all timeouts by this factor
TIMEOUT_SCALE=1.0

# Scale specific delay categories independently
DELAY_SCALE_NAVIGATION=1.0
DELAY_SCALE_MODAL=1.0
DELAY_SCALE_INPUT=1.0
DELAY_SCALE_ACTION=1.0
DELAY_SCALE_PACING=1.0

# -----------------------------------------------------------------------------
# OPTIONAL: Limits & Safety
# -----------------------------------------------------------------------------
# Maximum DMs per day (overrides profile config)
# MAX_DMS_PER_DAY=50

# Confidence threshold for creator detection (0-100)
CONFIDENCE_THRESHOLD=50

# -----------------------------------------------------------------------------
# OPTIONAL: Custom DM Message
# -----------------------------------------------------------------------------
# Custom DM message template (use {name} for username)
# DM_MESSAGE=Hey! Love your content 🔥

# -----------------------------------------------------------------------------
# OPTIONAL: Vision Model Selection
# -----------------------------------------------------------------------------
# AI model for vision analysis (default: google/gemini-flash-1.5)
# Options: google/gemini-flash-1.5, anthropic/claude-3-haiku, openai/gpt-4o-mini
# VISION_MODEL=google/gemini-flash-1.5

# -----------------------------------------------------------------------------
# OPTIONAL: Monitoring & Alerts
# -----------------------------------------------------------------------------
# Webhook URL for alerts (Discord, Slack, or generic JSON)
# Get Discord webhook: Server Settings > Integrations > Webhooks
# Get Slack webhook: api.slack.com/messaging/webhooks
# WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Notifications are sent for:
# - Data quality degradation (missing fields in extracted profiles)
# - Session failures
# - System health issues

# Error threshold before sending alert
# ERROR_THRESHOLD=5

# -----------------------------------------------------------------------------
# OPTIONAL: Advanced Browser Settings
# -----------------------------------------------------------------------------
# Run browser in headless mode (false = see browser window)
HEADLESS=true

# Custom user agent (leave empty for GoLogin default)
# USER_AGENT=

# Browser viewport size
# VIEWPORT_WIDTH=1920
# VIEWPORT_HEIGHT=1080

# -----------------------------------------------------------------------------
# OPTIONAL: Rate Limiting
# -----------------------------------------------------------------------------
# Requests per minute to Instagram
# RATE_LIMIT_PER_MINUTE=30

# Burst size for rate limiter
# RATE_LIMIT_BURST=10

# =============================================================================
# SETUP CHECKLIST
# =============================================================================
# [ ] Copy this file to .env
# [ ] Fill in SmartProxy credentials
# [ ] Fill in GoLogin API token
# [ ] Fill in Instagram credentials
# [ ] Fill in OpenRouter API key
# [ ] Set DATABASE_URL (or let Railway auto-provide)
# [ ] Create profiles.config.json from profiles.config.example.json
# [ ] Add individual GoLogin tokens to profiles.config.json
# [ ] Test with: npm run scrape -- --seed <username> --test
# =============================================================================

# =============================================================================
# SECURITY NOTES
# =============================================================================
# ⚠️  NEVER commit .env to git
# ⚠️  Keep credentials secure and rotate regularly
# ⚠️  Use strong, unique passwords
# ⚠️  Enable 2FA on all services when possible
# ⚠️  For production, use environment variables on your hosting platform
# =============================================================================
