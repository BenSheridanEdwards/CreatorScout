{
	"name": "scout",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"test": "NODE_OPTIONS='--experimental-vm-modules --max-old-space-size=8192' jest",
		"test:profileActions": "NODE_OPTIONS='--experimental-vm-modules --max-old-space-size=8192' jest functions/profile/profileActions/profileActions.test.ts --runInBand",
		"test:watch": "NODE_OPTIONS='--experimental-vm-modules --max-old-space-size=8192' jest --watch",
		"test:coverage": "NODE_OPTIONS='--experimental-vm-modules --max-old-space-size=8192' jest --coverage",
		"test:e2e": "NODE_OPTIONS=--experimental-vm-modules jest --testMatch='**/*.puppeteer.test.ts' --testTimeout=120000 --testPathIgnorePatterns='[]'",
		"test:e2e:scrape": "NODE_OPTIONS=--experimental-vm-modules jest tests/e2e/scrape_e2e.puppeteer.test.ts --testTimeout=120000 --testPathIgnorePatterns='[]'",
		"test:e2e:check-profile": "NODE_OPTIONS=--experimental-vm-modules jest tests/e2e/check_profile_e2e.puppeteer.test.ts --testTimeout=120000 --testPathIgnorePatterns='[]'",
		"login:screenshot": "tsx scripts/login_screenshot.ts",
		"discover": "tsx scripts/discover.ts",
		"analyze": "tsx scripts/analyze_profile.ts",
		"follow": "tsx scripts/follow_user.ts",
		"dm": "tsx scripts/dm_user.ts",
		"inbox": "tsx scripts/open_inbox.ts",
		"inspect": "tsx scripts/test_instagram_loads",
		"following": "tsx scripts/get_following.ts",
		"process": "tsx scripts/process_profiles.ts",
		"health": "tsx scripts/health_check.ts",
		"dashboard": "tsx scripts/dashboard.ts",
		"studio": "npx prisma studio",
		"dev:frontend": "cd frontend && npm run dev",
		"dev:server": "tsx server.ts"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.1.0",
		"@prisma/client": "^7.1.0",
		"dotenv": "^17.2.3",
		"ghost-cursor": "^1.4.1",
		"openai": "^6.10.0",
		"pg": "^8.16.3",
		"prisma": "^7.1.0",
		"puppeteer": "^22.13.1",
		"puppeteer-extra": "^3.3.6",
		"puppeteer-extra-plugin-stealth": "^2.11.2",
		"uuid": "^9.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.10.2",
		"@types/pg": "^8.16.0",
		"@types/puppeteer": "^5.4.7",
		"@types/uuid": "^10.0.0",
		"jest": "^30.2.0",
		"ts-jest": "^29.4.6",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
