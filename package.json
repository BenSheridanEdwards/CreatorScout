		"manual:mark-creator": "tsx scripts/manual_override.ts mark-creator",
		"manual:mark-not-creator": "tsx scripts/manual_override.ts mark-not-creator",
		"manual:clear": "tsx scripts/manual_override.ts clear",
		"manual:list": "tsx scripts/manual_override.ts list",
		"test:engagement": "tsx scripts/test_random_engagement.ts --profile test-account",
		"follow": "tsx scripts/follow_user.ts",
		"dm": "tsx scripts/dm_user.ts",
		"inbox": "tsx scripts/open_inbox.ts",
		"inspect": "tsx scripts/test_instagram_loads",
		"following": "tsx scripts/get_following.ts",
		"process": "tsx scripts/process_profiles.ts",
		"health": "tsx scripts/health_check.ts",
		"dashboard": "tsx scripts/dashboard.ts",
		"studio": "npx prisma studio",
		"dev:frontend": "cd frontend && npm run dev",
		"dev:server": "tsx server.ts",
		"test:profile": "tsx scripts/test/test_profile.ts",
		"test:rampup": "tsx scripts/test/ramp_up_test.ts",
		"costs": "tsx scripts/monitoring/costMonitor.ts",
		"cron:session": "tsx scripts/cron/sessionRunner.ts",
		"cron:smart": "tsx scripts/cron/smartSessionRunner.ts",
		"cron:reset": "tsx scripts/cron/resetDailyCounters.ts",
		"scroll": "tsx scripts/natural_scroll.ts",
		"test:dm": "tsx scripts/test_dm_variation.ts",
		"test:proxy": "tsx scripts/test_proxy.ts",
		"test:single-profile": "tsx scripts/test_profile.ts",
		"test:like": "tsx scripts/test_like_post.ts",
		"test:reel": "tsx scripts/test_watch_reel.ts",
		"profiles:list": "tsx scripts/list_profiles.ts",
		"profiles:sync": "tsx scripts/sync_profiles.ts",
		"profiles:sync:dry": "tsx scripts/sync_profiles.ts --dry-run",
		"profiles:sync:force": "tsx scripts/sync_profiles.ts --force",
		"adspower:list": "tsx scripts/list_adspower_profiles.ts",
		"cookies:clear": "tsx scripts/clear_cookies.ts",
		"start:production": "tsx scripts/deploy/start.ts",
		"scheduler:start": "tsx -e \"import { startScheduler } from './functions/scheduling/nodeScheduler.ts'; startScheduler().then(() => console.log('Scheduler started'))\"",
		"proxy:usage": "tsx -e \"import { getTodayProxyUsage, estimateMonthlyProxyCost } from './functions/shared/proxy/proxyOptimizer.ts'; Promise.all([getTodayProxyUsage(), estimateMonthlyProxyCost()]).then(([t,m]) => console.log('Today:', t, 'Monthly:', m))\""
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.1.0",
		"@prisma/client": "^7.1.0",
		"cron-parser": "^5.4.0",
		"dotenv": "^17.2.3",
		"ghost-cursor": "^1.4.1",
		"openai": "^6.10.0",
		"pg": "^8.16.3",
		"prisma": "^7.1.0",
		"puppeteer": "^22.13.1",
		"tsx": "^4.21.0",
		"uuid": "^9.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@types/jest": "^30.0.0",
		"@types/jsdom": "^27.0.0",
		"@types/node": "^24.10.2",
		"@types/pg": "^8.16.0",
		"@types/puppeteer": "^5.4.7",
		"@types/uuid": "^10.0.0",
		"jest": "^30.2.0",
		"jsdom": "^27.4.0",
		"ts-jest": "^29.4.6",
		"typescript": "^5.9.3"
	}
}
